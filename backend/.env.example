# Server Configuration
PORT=5000

# Supabase Configuration (Backend - Service Role)
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Database Tables
SUPABASE_BATCHES_TABLE=batches
SUPABASE_FARMERS_TABLE=farmer_records
SUPABASE_SCAN_RECORDS_TABLE=dealer_scan_records

# Twilio Configuration (OTP Service)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid_here

# OpenRouter AI Configuration (Optional)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=poolside/laguna-m.1:free
